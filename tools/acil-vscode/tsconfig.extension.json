{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "lib": ["ES2022"],
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "declaration": false,
    "sourceMap": true,
    "skipLibCheck": true,
    "types": ["node"],
    "noUncheckedSideEffectImports": false
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
